          "stringUnit" : {
            "state" : "translated",
            "value" : "Har bir chop etilgan varaqni ko'ndalangiga (gorizontal) o'rtasidan bir marta kesing — yuqori qator pastki qatordan ajraladi"
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Har bir chop etilgan varaqni ko'ndalangiga (gorizontal) o'rtasidan bir marta kesing — yuqori qator pastki qatordan ajraladi"
          }
        }
      }
    },
    "str.help_print4_step9" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stapeln Sie alle oberen Hälften auf alle unteren Hälften und behalten Sie in jedem Stapel die Druckreihenfolge bei"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stack every top half on top of every bottom half, keeping each pile in the printed sheet order"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Empilez chaque moitié supérieure au-dessus des moitiés inférieures, en conservant l'ordre d'impression dans chaque pile"
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Har bir yuqori yarmni har bir pastki yarmning ustiga qo'ying, har bir to'plamda chop etish tartibini saqlang"
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Har bir yuqori yarmni har bir pastki yarmning ustiga qo'ying, har bir to'plamda chop etish tartibini saqlang"
          }
        }
      }
    },
    "str.help_print4_step10" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falten Sie den gesamten Stapel mittig entlang der vertikalen Mitte, sodass die rechte Spalte außen als Titelseite liegt"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fold the whole stack in half along the vertical center so the right-hand column ends up on the outside as the cover"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pliez toute la pile en deux le long de l'axe vertical central, de sorte que la colonne de droite se retrouve à l'extérieur comme couverture"
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Butun dastani vertikal markaz bo'ylab ikkiga buklang — o'ng tomondagi ustun tashqarida muqova bo'lib qoladi"
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Butun dastani vertikal markaz bo'ylab ikkiga buklang — o'ng tomondagi ustun tashqarida muqova bo'lib qoladi"
          }
        }
      }
    },
    "str.help_print4_step11" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heften Sie entlang der Faltung, um das Heft zu binden"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Staple along the fold to bind the booklet"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agrafez le long du pli pour relier le livret"
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
