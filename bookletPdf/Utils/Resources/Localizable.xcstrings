    "str.help_about_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwandeln Sie gewöhnliche PDFs mühelos in Broschüren. Unsere App ordnet Ihre PDF-Seiten in ein professionelles Broschürenformat um, das sofort für den Druck bereit ist. Mit Unterstützung für 2-in-1 und 4-in-1 Layouts können Sie die perfekte Broschüre für Ihre Bedürfnisse erstellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transform regular PDFs into booklets effortlessly. Our app rearranges your PDF pages into a professional booklet format ready for printing. With support for both 2-in-1 and 4-in-1 layouts, you can create the perfect booklet for your needs."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Transformez facilement des PDF ordinaires en livrets. Notre application réorganise les pages de votre PDF dans un format de livret professionnel prêt pour l'impression. Avec la prise en charge des mises en page 2-en-1 et 4-en-1, vous pouvez créer le livret parfait pour vos besoins."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oddiy PDF fayllarni kitobchaga osonlikcha aylantiring. Bizning ilovamiz sizning PDF sahifalaringizni professional kitobcha formatiga o'tkazadi va chop etishga tayyor qiladi. 2-dan-1 va 4-dan-1 joylashuvlarni qo'llab-quvvatlagan holda, ehtiyojlaringizga mos mukammal kitobcha yaratishingiz mumkin."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Oddiy PDF fayllarni kitobchaga osonlikcha aylantiring. Bizning ilovamiz sizning PDF sahifalaringizni professional kitobcha formatiga o'tkazadi va chop etishga tayyor qiladi. 2-dan-1 va 4-dan-1 joylashuvlarni qo'llab-quvvatlagan holda, ehtiyojlaringizga mos mukammal kitobcha yaratishingiz mumkin."
          }
        }
      }
    },
