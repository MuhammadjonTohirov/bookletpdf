    "str.help_print2_step6d" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wichtig: Drucker verhalten sich unterschiedlich. Wenn die Rückseite auf dem Kopf steht oder vertauscht ist, legen Sie das Papier von der anderen Seite wieder ein oder drehen Sie den Stapel und testen Sie zuerst mit zwei Blättern"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Important: printers differ. If the back side comes out upside down or reversed, try inserting the paper from the other side or rotate the stack and test with two sheets first"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Important : les imprimantes different. Si le verso sort a l'envers ou inverse, essayez de reinserer le papier de l'autre cote ou tournez la pile et testez d'abord avec deux feuilles"
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muhim: printerlar bir-biridan farq qiladi. Agar orqa tomon teskari yoki almashib chiqsa, qog'ozni boshqa tomondan qayta joylab ko'ring yoki to'plamni aylantirib avval ikki varaq bilan sinab ko'ring"
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
