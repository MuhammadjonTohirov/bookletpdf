      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach dem Drucken falten Sie die Seiten zweimal in der Mitte, um Ihre Broschüre zu erstellen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After printing, fold pages in half twice to create your booklet"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apres impression, pliez les pages en deux deux fois pour creer votre livret"
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chop etgandan keyin, kitobchangizni yaratish uchun sahifalarni ikki marta yarmga bukling"
