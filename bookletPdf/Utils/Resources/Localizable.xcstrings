    "str.print_assistant_back_body_2in1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entnehmen Sie die gedruckten Seiten, drehen Sie den Stapel oben-unten um und legen Sie ihn wieder in das Fach. Dann tippen Sie auf Drucken."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Take the printed pages out without changing their order. Flip the whole stack top-to-bottom: keep left and right the same, so the top/head edge becomes the bottom edge. Put it back in the tray and tap Print."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retirez les pages imprimées, retournez toute la pile haut-bas et replacez-la dans le bac. Puis appuyez sur Imprimer."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chop etilgan qog'ozlarni oling, ularni tepa-pastga ag'daring va yana printerga joylang. So'ng Chop etishni bosing."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chop etilgan qog'ozlarni oling, ularni tepa-pastga ag'daring va yana printerga joylang. So'ng Chop etishni bosing."
          }
        }
      }
    },
    "str.print_assistant_back_body_4in1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nehmen Sie die bedruckten Seiten heraus, ohne ihre Reihenfolge zu ändern. Drehen Sie den ganzen Stapel so, dass die obere Kante oben bleibt — links und rechts bleiben ebenfalls auf derselben Seite. Legen Sie ihn wieder ein und tippen Sie auf Drucken."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Take the printed pages out without changing their order. Flip the whole stack so the head edge stays at the top — left and right also stay on the same sides. Put it back in the tray and tap Print."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sortez les pages imprimées sans changer leur ordre. Retournez toute la pile en gardant le bord supérieur en haut — la gauche et la droite restent aussi du même côté. Remettez-la dans le bac et touchez Imprimer."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chop etilgan sahifalarni tartibini o'zgartirmasdan oling. Butun dastani yuqori qirrasi tepada qoladigan tarzda aylantiring — chap va o'ng tomonlari ham o'sha tomonida qoladi. Lotokka qaytaring va Chop etish-ni bosing."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chop etilgan sahifalarni tartibini o'zgartirmasdan oling. Butun dastani yuqori qirrasi tepada qoladigan tarzda aylantiring — chap va o'ng tomonlari ham o'sha tomonida qoladi. Lotokka qaytaring va Chop etish-ni bosing."
          }
        }
      }
    },
    "str.print_assistant_back_title" : {
      "extractionState" : "manual",
      "localizations" : {
