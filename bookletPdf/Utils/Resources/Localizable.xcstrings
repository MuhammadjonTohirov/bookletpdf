    "str.help_print4_step6d" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wichtig: Drucker unterscheiden sich. Wenn die Rückseite auf dem Kopf steht oder gespiegelt ist, legen Sie das Papier von der anderen Seite ein oder drehen Sie den Stapel und testen Sie zuerst mit zwei Blättern"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Important: printers differ. If the back side comes out upside down or reversed, try inserting the paper from the other side or rotate the stack and test with two sheets first"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Important : les imprimantes different. Si le verso sort a l'envers ou inverse, essayez d'inserer le papier par l'autre cote ou faites pivoter la pile et testez d'abord avec deux feuilles"
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muhim: printerlar bir-biridan farq qiladi. Agar orqa tomoni teskari yoki noto'g'ri chiqsa, qog'ozni boshqa tomondan joylab ko'ring yoki to'plamni aylantirib, avval ikki varaq bilan sinab ko'ring"
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Muhim: printerlar bir-biridan farq qiladi. Agar orqa tomoni teskari yoki noto'g'ri chiqsa, qog'ozni boshqa tomondan joylab ko'ring yoki to'plamni aylantirib, avval ikki varaq bilan sinab ko'ring"
          }
        }
      }
    },
