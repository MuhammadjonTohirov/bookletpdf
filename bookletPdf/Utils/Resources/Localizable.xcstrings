    "str.help_print2_step6" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nehmen Sie den bedruckten Stapel heraus, drehen Sie ihn von oben nach unten (die obere Kante wird zur unteren Kante) und legen Sie ihn wieder in das Papierfach"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pull out the printed stack, flip it top-to-bottom (head edge becomes the foot edge), and put it back in the paper tray"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sortez la pile imprimée, retournez-la de haut en bas (le bord supérieur devient le bord inférieur) et remettez-la dans le bac à papier"
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chop etilgan dastani lotokdan oling, uni yuqoridan pastga aylantiring (yuqori qirrasi pastki qirrasiga aylanadi) va lotokka qaytaring"
          }
        },
        "uz-UZ" : {
