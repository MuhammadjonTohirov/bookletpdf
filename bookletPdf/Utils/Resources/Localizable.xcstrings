    "str.whats_new_feature_ios_desc" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein zweistufiger Assistent führt Sie durch das Drucken der Vorderseite, das Wenden des Stapels und das Drucken der Rückseite — alles auf iOS."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A guided two-step assistant walks you through printing the front, flipping the stack, and printing the back — all from iOS."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un assistant en deux étapes vous guide pour imprimer le recto, retourner la pile et imprimer le verso — directement depuis iOS."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ikki bosqichli yordamchi old tomonni chop etishda, dastani aylantirishda va orqa tomonni chop etishda yo'l ko'rsatadi — barchasi iOS'da."
          }
        },
        "uz-UZ" : {
