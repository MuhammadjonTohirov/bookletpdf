    "str.cache_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF-Vorschaubilder werden zwischengespeichert, um die Leistung zu verbessern. Sie können den Cache löschen, um Speicherplatz freizugeben."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PDF thumbnails are cached to improve performance. You can clear the cache to free up disk space."
