    "str.printing_instructions_2in1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When The Drucken Dialog Appears 1. Auswählen \"pages Per Sheet 2\" In The Layout Section 2. Choose Appropriate Orientation For Your Broschüre 3. For Best Results With Double-sided Printing - First Drucken Odd Seiten - Then Flip Paper And Drucken Even Seiten"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When the print dialog appears:\n\n1. Select \"Pages per Sheet: 2\" in the Layout section\n2. Choose appropriate orientation for your booklet\n3. For best results with double-sided printing:\n   - First print odd pages\n   - Then flip paper and print even pages"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When The Imprimer Dialog Appears 1. Sélectionner \"pages Per Sheet 2\" In The Layout Section 2. Choose Appropriate Orientation For Your Brochure 3. For Best Results With Double-sided Printing - First Imprimer Odd Pages - Then Flip Paper And Imprimer Even Pages"
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When The Chop etish Dialog Appears 1. Tanlash \"pages Per Sheet 2\" In The Layout Section 2. Choose Appropriate Orientation For Your Buklet 3. For Best Results With Double-sided Printing - First Chop etish Odd Sahifalar - Then Flip Paper And Chop etish Even Sahifalar"
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When The Chop etish Dialog Appears 1. Tanlash \"pages Per Sheet 2\" In The Layout Section 2. Choose Appropriate Orientation For Your Buklet 3. For Best Results With Double-sided Printing - First Chop etish Odd Sahifalar - Then Flip Paper And Chop etish Even Sahifalar"
          }
        }
      }
    },
    "str.printing_instructions_4in1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For 4-in-1 Broschüre Printing 1. Auswählen \"pages Per Sheet 1\" (pages Are Already Arranged 4-up) 2. Set Paper Orientation To Match Your Dokument 3. For Double-sided Printing - Drucken All Seiten - Ensure \"print On Both Sides\" Is Selected - Choose \"flip On Short Edge\" Binding Option 4. After Printing, Fold Seiten In Half Twice To Create Your Broschüre"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For 4-in-1 booklet printing:\n\n1. Select \"Pages per Sheet: 1\" (pages are already arranged 4-up)\n2. Set paper orientation to match your document\n3. For double-sided printing:\n   - Print all pages\n   - Ensure \"Print on both sides\" is selected\n   - Choose \"Flip on short edge\" binding option\n4. After printing, fold pages in half twice to create your booklet"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For 4-in-1 Brochure Printing 1. Sélectionner \"pages Per Sheet 1\" (pages Are Already Arranged 4-up) 2. Set Paper Orientation To Match Your Document 3. For Double-sided Printing - Imprimer All Pages - Ensure \"print On Both Sides\" Is Selected - Choose \"flip On Short Edge\" Binding Option 4. After Printing, Fold Pages In Half Twice To Create Your Brochure"
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For 4-in-1 Buklet Printing 1. Tanlash \"pages Per Sheet 1\" (pages Are Already Arranged 4-up) 2. Set Paper Orientation To Match Your Hujjat 3. For Double-sided Printing - Chop etish All Sahifalar - Ensure \"print On Both Sides\" Is Selected - Choose \"flip On Short Edge\" Binding Option 4. After Printing, Fold Sahifalar In Half Twice To Create Your Buklet"
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For 4-in-1 Buklet Printing 1. Tanlash \"pages Per Sheet 1\" (pages Are Already Arranged 4-up) 2. Set Paper Orientation To Match Your Hujjat 3. For Double-sided Printing - Chop etish All Sahifalar - Ensure \"print On Both Sides\" Is Selected - Choose \"flip On Short Edge\" Binding Option 4. After Printing, Fold Sahifalar In Half Twice To Create Your Buklet"
          }
        }
      }
    },
