    "str.print_assistant_done_body" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Falten Sie den Stapel in der Mitte und heften Sie den Rücken, um Ihre Broschüre fertigzustellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fold the stack in half along the center and staple the spine to finish your booklet."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pliez la pile en deux au centre et agrafez la reliure pour terminer votre brochure."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qog'ozlarni o'rtadan buklang va bukletni yakunlash uchun tikib qo'ying."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Qog'ozlarni o'rtadan buklang va bukletni yakunlash uchun tikib qo'ying."
          }
        }
      }
    },
    "str.print_assistant_done_body_4in1" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schneiden Sie jedes bedruckte Blatt horizontal in der Mitte durch. Stapeln Sie alle oberen Hälften auf alle unteren Hälften (in Druckreihenfolge), falten Sie den gesamten Stapel mittig entlang der Vertikalen mit der rechten Spalte außen und heften Sie entlang der Faltung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cut every printed sheet horizontally across the middle. Stack every top half on top of every bottom half (in printed order), fold the whole stack vertically down the center with the right-hand column on the outside, and staple along the fold."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Coupez chaque feuille imprimée horizontalement en son milieu. Empilez chaque moitié supérieure au-dessus des moitiés inférieures (dans l'ordre d'impression), pliez toute la pile verticalement le long du centre avec la colonne de droite à l'extérieur, puis agrafez le long du pli."
          }
        },
        "uz" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Har bir chop etilgan varaqni ko'ndalangiga o'rtasidan kesing. Har bir yuqori yarmni har bir pastki yarmning ustiga qo'ying (chop etish tartibida), butun dastani vertikal markaz bo'ylab — o'ng tomondagi ustun tashqarida — buklang va buklash chizig'i bo'ylab steplerda biriktiring."
          }
        },
        "uz-UZ" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Har bir chop etilgan varaqni ko'ndalangiga o'rtasidan kesing. Har bir yuqori yarmni har bir pastki yarmning ustiga qo'ying (chop etish tartibida), butun dastani vertikal markaz bo'ylab — o'ng tomondagi ustun tashqarida — buklang va buklash chizig'i bo'ylab steplerda biriktiring."
          }
        }
      }
    },
